{
  "name": "joplin-plugin-knowledge-graph",
  "version": "1.0.0",
  "description": "AI Agent Knowledge Graph plugin for Joplin - Obsidian-like wiki-links and temporal knowledge graph",
  "author": "AI Agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [
    "joplin",
    "plugin",
    "knowledge-graph",
    "ai-agent",
    "wiki-links"
  ],
  "joplinPlugin": {
    "manifestVersion": 1,
    "minAppVersion": "2.14",
    "platforms": [
      "desktop"
    ],
    " couplings": [
      "titlebarKeychain"
    ],
    "contentScripts": [
      {
        "id": "knowledgeGraphContentScript",
        "type": "global",
        "file": "./dist/content_script.js"
      }
    ]
  },
  "scripts": {
    "dev": "webpack --mode development",
    "build": "webpack --mode production",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "pack": "webpack --mode production && zip -r ../knowledge-graph.jpl dist/"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-transition": "^3.0.9",
    "@types/d3-zoom": "^3.0.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "copy-webpack-plugin": "^12.0.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-transition": "^3.0.1",
    "d3-zoom": "^3.0.0",
    "uuid": "^9.0.1"
  }
}
